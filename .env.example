# ============================================================
# AgendaPro - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no repositório!
# ============================================================

# Ambiente: development | production
NODE_ENV=production

# Porta do servidor (o Render define automaticamente)
PORT=3000

# OBRIGATÓRIO: Chave secreta para as sessões (gere uma string aleatória longa)
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=TROQUE_POR_UMA_STRING_ALEATORIA_LONGA_AQUI

# Senha do admin padrão (opcional, padrão: admin123)
# RECOMENDADO: Defina uma senha forte aqui
ADMIN_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE

# Origens permitidas para CORS (separadas por vírgula)
# Exemplo: https://meusite.onrender.com,https://meudominio.com.br
ALLOWED_ORIGINS=https://sistema-agendamento-0vzz.onrender.com
